pipeline {
    
    agent any 
    
    environment {
        IMAGE_TAG = "${BUILD_NUMBER}"
     }

    stages {

     stage('Checkout'){
           steps {
           git branch: 'master',
           url: 'https://github.com/Syamlal-M/cicd-pythonapplication'           
}
        }

    stage('load') {
      steps {
       sh 'cat /proc/cpuinfo'
       sh 'cat /etc/os-release'
      }
    }
 stage('Build Docker'){
            steps{
                script{
                    sh '''
                    echo 'Buid Docker Image'
                    docker build -t python/cicd:${BUILD_NUMBER} .
}
}
}

stage('imagename') {
      steps {
       sh 'docker image ls'
      
      }
    }

}
}
