pipeline {

    agent any

    environment {
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Syamlal-M/cicd-pythonapplication'
            }
        }

        stage('Load') {
            steps {
                sh 'cat /proc/cpuinfo'
                sh 'cat /etc/os-release'
            }
        }

        stage('Build Docker') {
            steps {
                script {
                    sh '''
                        echo "Build Docker Image"
                        docker build -t python/cicd:${BUILD_NUMBER} .
                    '''
                }
            }
        }
    }
}
